<Page x:Class="AvailabilityManager.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AvailabilityManager"
        mc:Ignorable="d"
        Title="SG Titans AvailabilityManager" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Login-Header -->
        <Label Grid.Row="0" Grid.Column="1" 
               HorizontalAlignment="Center" VerticalAlignment="Bottom" 
               Content="Login" FontSize="42" FontWeight="Black"/>

        <!-- UserName Input -->
        <Label Grid.Row="1" Grid.Column="0"  
               VerticalAlignment="Bottom" HorizontalAlignment="Center" 
               Margin="10" Content="Username 👤"/>
        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                 Height="30" Width="500" 
                 VerticalAlignment="Bottom" VerticalContentAlignment="Center"
                 Padding="5,0,0,0"
                 Margin="55,0,0,10"/>

        <!-- Password Input -->
        <Label Grid.Row="2" Grid.Column="0"  
               VerticalAlignment="Top" HorizontalAlignment="Center" 
               Margin="10" Content="Password 🔒"/>
        <PasswordBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" 
                 Height="30" Width="500" 
                 VerticalAlignment="Top" VerticalContentAlignment="Center"
                 Padding="5,0,0,0"
                 Margin="55,10,0,0"/>



        <Button Grid.Row="2" Grid.Column="1" Grid.RowSpan="2" VerticalAlignment="Center" 
                HorizontalAlignment="Center" VerticalContentAlignment="Center"              
                Background="DeepSkyBlue"
                Foreground="Black"                             
                Content="Login"
                FontSize="20"
                FontWeight="Bold"
                Width="175"
                Height="40"
                Click="OnClick1"
                BorderBrush="CornflowerBlue"
                BorderThickness="4">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="15"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Page>
