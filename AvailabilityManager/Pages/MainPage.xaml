<Page x:Class="AvailabilityManager.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AvailabilityManager"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1200"
      Title="MainPage">

    <Grid>

        <Grid.Resources>
            <Style TargetType="{x:Type Label}">
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="0.2*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.2*"/>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.2*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Column="1" Grid.ColumnSpan="7" FontSize="18">KW 23 (10.05.2026 - 16.05.2026)</Label>

        <Label Grid.Column="0" Grid.ColumnSpan="7" Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center"
               Content="Verfügbarkeiten" FontSize="25"/>


        <StackPanel>
            
        </StackPanel>
        <StackPanel Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Label Content="10.05. Montag:"/>
            <Label Content="11.05. Dienstag: "/>
            <Label Content="12.05. Mittwoch: "/>
            <Label Content="13.05. Donnerstag: "/>
            <Label Content="14.05. Freitag: "/>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.RowSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center" 
                    Width="250" Margin="10,8,0,0">
            <StackPanel.Resources>
                <Style TargetType="{x:Type TextBox}">
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Height" Value="18"/>
                </Style>
            </StackPanel.Resources>
            <TextBox/>
            <TextBox/>
            <TextBox/>
            <TextBox/>
            <TextBox/>
        </StackPanel>

        <StackPanel Grid.Column="4" Grid.RowSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center"
                    Margin="0,0,0,80">
            <Label Content="15.05. Samstag: "/>
            <Label Content="16.05. Sonntag: "/>
        </StackPanel>

        <StackPanel Grid.Column="5" Grid.RowSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center"
                    Width="250" Margin="10,49,0,80">
            <StackPanel.Resources>
                <Style TargetType="{x:Type TextBox}">
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Height" Value="18"/>
                </Style>
            </StackPanel.Resources>
            <TextBox/>
            <TextBox/>
            <Button Grid.Row="1" Grid.Column="5" Content="Speichern" FontWeight="Bold"
                    Height="22" Width="75" VerticalContentAlignment="Center"
                    Background="Lime" HorizontalAlignment="Right" Margin="0,19,0,0"
                    BorderBrush="Black" BorderThickness="2">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>



        <DataGrid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5">

        </DataGrid>
    </Grid>
</Page>
